module tfc_tb;

    reg clk;
    reg reset;

    wire red;
    wire green;
    wire yellow;

    // DUT Instantiation
    tfc DUT (
        .clk(clk),
        .reset(reset),
        .red(red),
        .green(green),
        .yellow(yellow)
    );

    // Monitoring signals
    initial begin
        $monitor("clk=%d reset=%d red=%d green=%d yellow=%d",
                  clk, reset, red, green, yellow);
    end

    // Clock generation
    always begin
        #5 clk = ~clk;
    end

    // Stimulus
    initial begin
        clk = 0;
        reset = 1;

        #20;
        reset = 0;

        #100;
        $stop;
    end

endmodule
