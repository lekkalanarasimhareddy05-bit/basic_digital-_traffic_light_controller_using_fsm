module tfc (
    input clk,
    input reset,
    output reg red,
    output reg green,
    output reg yellow
);

    // State encoding
    parameter RED_ST    = 2'b00;
    parameter GREEN_ST  = 2'b01;
    parameter YELLOW_ST = 2'b10;

    reg [1:0] state, next_state;

    // State register
    always @(posedge clk or posedge reset) begin
        if (reset)
            state <= RED_ST;
        else
            state <= next_state;
    end

    // Next state logic
    always @(*) begin
        case (state)
            RED_ST:    next_state = GREEN_ST;
            GREEN_ST:  next_state = YELLOW_ST;
            YELLOW_ST: next_state = RED_ST;
            default:   next_state = RED_ST;
        endcase
    end

    // Output logic
    always @(*) begin
        // default off
        red = 0;
        green = 0;
        yellow = 0;

        if (state == RED_ST)
            red = 1;
        else if (state == GREEN_ST)
            green = 1;
        else if (state == YELLOW_ST)
            yellow = 1;
    end

endmodule
